# Reference material downloaded from vendor (too large / licensed)
/ref/

# macOS
.DS_Store

# Editor
.vscode/
.idea/

# ESP-IDF build artifacts
build/
sdkconfig
sdkconfig.old
dependencies.lock
managed_components/

# Large binary model artifacts (downloaded/generated via tools/)
projects/*/spiffs/*.tflite
projects/*/spiffs/*.bin
projects/*/hf/*.tflite
projects/*/tools/.yamnet_work/

# Wi-Fi creds live in sdkconfig.defaults — never commit the real file; only the template
projects/*/sdkconfig.defaults

# Python
__pycache__/
*.pyc
.venv/
.venv-analysis/
venv/
/logs/
projects/*/.cache/
projects/*/tools/.models-backup/
projects/*/tools/.yamnet_work/

# Claude Code runtime state
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Personal drafts, negotiation notes, anything not for publication
docs/private/

# Internal working notes (plans, todos, audits) — kept local, not for public repo.
docs/internal/

# Session reports + analyses that reference real-home capture timestamps.
# Patterns match dated files; if you add a new analysis that references
# real session data, name it to fit one of these or move under docs/internal/.
docs/research/night-session-*.md
docs/research/deployment-*.md
docs/research/deep-analysis-*.md
docs/research/embed-clf-*.md
docs/research/data-reassessment-*.md

# Whole datasets/ tree is private by default — captures, labels, releases,
# inventories, READMEs all reference real-home recordings. Backed up via
# tools/backup-data.sh into ~/Backups/ws-ESP32-S3-CAM/.
datasets/

# README inside hf/ describes private dataset provenance.
projects/cry-detect-01/hf/README.md

# Trained model artifacts derived from private audio (sklearn pickles, etc).
# yamnet.tflite is already covered by the projects/*/hf/*.tflite rule above.
projects/*/hf/*.pkl

# ML researcher's lab notebooks — gitignored like raw data.
# Conventions in `.claude/commands/ml-researcher.md` §Workflow.
# Only the experiments-dir conventions README is in git;
# everything inside experiment subdirs (notebooks, intermediate
# models, plots) stays local.
projects/cry-detect-01/ml-experiments/*
!projects/cry-detect-01/ml-experiments/README.md
!projects/cry-detect-01/ml-experiments/.gitkeep

# Raw session data (WAVs, device-logs, derived audit artifacts).
# Backed up via tools/backup-data.sh into ~/Backups/ws-ESP32-S3-CAM/.
projects/cry-detect-01/logs/
